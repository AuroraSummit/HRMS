<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.attendance.dao.LeaveApplicationDao">

    <select id="selectByEmpId" resultType="com.hrms.module.attendance.entity.LeaveApplication">
        SELECT * FROM att_leave WHERE emp_id = #{empId} AND is_deleted = 0 ORDER BY create_time DESC
    </select>

</mapper>

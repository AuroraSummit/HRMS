<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.org.dao.PositionDao">

    <select id="selectByDeptId" resultType="com.hrms.module.org.entity.Position">
        SELECT * FROM org_position WHERE dept_id = #{deptId} AND is_deleted = 0 ORDER BY sort ASC
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.recruitment.dao.InterviewRecordDao">

    <select id="selectByDemandId" resultType="com.hrms.module.recruitment.entity.InterviewRecord">
        SELECT * FROM rec_interview WHERE demand_id = #{demandId} AND is_deleted = 0 ORDER BY round ASC
    </select>

</mapper>

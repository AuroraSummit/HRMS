<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.recruitment.dao.OfferRecordDao">

    <select id="selectByDemandId" resultType="com.hrms.module.recruitment.entity.OfferRecord">
        SELECT * FROM rec_offer WHERE demand_id = #{demandId} AND is_deleted = 0
    </select>

</mapper>

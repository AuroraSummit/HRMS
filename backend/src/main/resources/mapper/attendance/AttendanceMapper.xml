<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.attendance.dao.AttendanceDao">

    <select id="selectByEmpIdAndDate" resultType="com.hrms.module.attendance.entity.Attendance">
        SELECT * FROM att_attendance WHERE emp_id = #{empId} AND attendance_date = #{date} AND is_deleted = 0
    </select>

</mapper>

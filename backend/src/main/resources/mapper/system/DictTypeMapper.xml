<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.system.dao.DictTypeDao">
    <select id="selectByCode" resultType="com.hrms.module.system.entity.DictType">
        SELECT * FROM sys_dict_type WHERE code = #{code} AND is_deleted = 0
    </select>
</mapper>

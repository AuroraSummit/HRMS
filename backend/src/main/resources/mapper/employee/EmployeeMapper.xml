<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.employee.dao.EmployeeDao">

    <resultMap id="EmployeeVOResultMap" type="com.hrms.module.employee.vo.EmployeeDetailVO">
        <id column="id" property="id"/>
        <result column="emp_no" property="empNo"/>
        <result column="name" property="name"/>
        <result column="gender" property="gender"/>
        <result column="birthday" property="birthday"/>
        <result column="id_card" property="idCard"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="dept_id" property="deptId"/>
        <result column="position_id" property="positionId"/>
        <result column="hire_date" property="hireDate"/>
        <result column="status" property="status"/>
        <result column="employment_type" property="employmentType"/>
        <result column="source" property="source"/>
        <result column="emergency_contact" property="emergencyContact"/>
        <result column="emergency_phone" property="emergencyPhone"/>
        <result column="dept_name" property="deptName"/>
        <result column="position_name" property="positionName"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 联查部门名岗位名，模糊搜索 -->
    <select id="selectEmployeeWithDeptAndPosition" resultMap="EmployeeVOResultMap">
        SELECT e.*, d.name AS dept_name, p.name AS position_name
        FROM emp_employee e
        LEFT JOIN org_department d ON e.dept_id = d.id AND d.is_deleted = 0
        LEFT JOIN org_position p ON e.position_id = p.id AND p.is_deleted = 0
        <where>
            e.is_deleted = 0
            <if test="queryDto.name != null and queryDto.name != ''">
                AND e.name LIKE CONCAT('%', #{queryDto.name}, '%')
            </if>
            <if test="queryDto.empNo != null and queryDto.empNo != ''">
                AND e.emp_no LIKE CONCAT('%', #{queryDto.empNo}, '%')
            </if>
            <if test="queryDto.deptId != null">
                AND e.dept_id = #{queryDto.deptId}
            </if>
            <if test="queryDto.status != null">
                AND e.status = #{queryDto.status}
            </if>
            <if test="queryDto.employmentType != null">
                AND e.employment_type = #{queryDto.employmentType}
            </if>
        </where>
        ORDER BY e.id DESC
    </select>

</mapper>

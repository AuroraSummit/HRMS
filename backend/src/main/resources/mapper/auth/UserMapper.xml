<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.module.auth.dao.UserDao">

    <!-- 基础查询 -->
    <select id="selectByUsername" resultType="com.hrms.module.auth.entity.User">
        SELECT * FROM auth_user WHERE username = #{username} AND is_deleted = 0
    </select>

</mapper>
